        title: "Taça de champanhe",
        img: "https://images.unsplash.com/photo-1543007630-9710e4a00a20?w=600&q=80",
        prompt: "Elegant birthday celebration portrait, woman holding champagne flute, bubbles close-up in foreground, elegant evening dress, soft warm ambient light, luxury party atmosphere, fine art photography, selective focus.",
        cat: "Pose",
        tags: ["champanhe", "elegante", "festa"]
      },
      {
        id: 10,
        title: "Espelho e reflexos",
        img: "https://images.unsplash.com/photo-1524638431109-93d95c968f03?w=600&q=80",
        prompt: "Creative birthday portrait using mirrors, multiple reflections of subject, elegant outfit, soft ambient light, art deco aesthetic, fashion editorial style, sophisticated composition, blush and gold color palette.",
        cat: "Cenário",
        tags: ["espelho", "reflexo", "art deco"]
      }
    ];

    // ── ESTADO ──
    let cards = [];
    let editId = null;
    let currentTags = [];
    let activeFilter = "Todos";

    function loadData() {
      try {
        const saved = localStorage.getItem('catalogo_ensaio_v2');
        cards = saved ? JSON.parse(saved) : INITIAL.map(c => ({ ...c }));
      } catch (e) {
        cards = INITIAL.map(c => ({ ...c }));
      }
    }

    function saveData() {
      try { localStorage.setItem('catalogo_ensaio_v2', JSON.stringify(cards)); } catch (e) {}
    }

    // ── RENDER ──
    function render(data) {
      const grid = document.getElementById('grid');
      if (!data.length) {
        grid.innerHTML = '<div class="empty"><p>📷</p><p>Nenhuma foto encontrada</p></div>';
        return;
      }
      grid.innerHTML = data.map((c, i) => `
        <div class="card" style="animation-delay:${i * 0.04}s">
          ${c.img
            ? `<div class="card-img-wrap" onclick="openLightbox('${c.img.replace(/'/g,"\\'")}')">
                <img src="${c.img}" alt="${c.title}" loading="lazy" onerror="this.parentElement.innerHTML='<div class=\\'card-img-placeholder\\'><span>🖼</span><p>Imagem indisponível</p></div>'" />
                <span class="card-badge">${c.cat}</span>
                <span class="card-num-badge">#${String(c.id).padStart(2,'0')}</span>
               </div>`
            : `<div class="card-img-placeholder" onclick="editCard(${c.id})">
                <span>📷</span><p>Adicionar imagem</p>
                <span class="card-badge">${c.cat}</span>
               </div>`
          }
          <div class="card-body">
            <div class="card-title">${c.title}</div>
            <div class="card-prompt">${c.prompt}</div>
            <div class="card-tags">${(c.tags||[]).map(t=>`<span class="tag">${t}</span>`).join('')}</div>
          </div>
          <div class="card-actions">
            <button class="btn-sm btn-edit" onclick="editCard(${c.id})">✏ Editar</button>
            <button class="btn-sm btn-copy" onclick="copyPrompt(${c.id})">⎘ Copiar prompt</button>
            <button class="btn-sm btn-del" onclick="deleteCard(${c.id})" title="Excluir">✕</button>
          </div>
        </div>
      `).join('');

      document.getElementById('count').textContent = cards.length;
      const cats = [...new Set(cards.map(c => c.cat))];
      document.getElementById('cat-count').textContent = cats.size || cats.length;
      renderFilters(cats);
    }

    function renderFilters(cats) {
      const container = document.getElementById('filter-btns');
      const all = ['Todos', ...cats];
      container.innerHTML = all.map(cat => `
        <button class="filter-btn ${activeFilter === cat ? 'active' : ''}" data-cat="${cat}" onclick="setFilter(this)">${cat}</button>
      `).join('');
    }

    function setFilter(btn) {
      activeFilter = btn.dataset.cat;
      filterCards();
    }

    function filterCards() {
      const q = document.getElementById('search').value.toLowerCase();
      let filtered = cards;
      if (activeFilter !== 'Todos') filtered = filtered.filter(c => c.cat === activeFilter);
      if (q) filtered = filtered.filter(c =>
        c.title.toLowerCase().includes(q) ||
        c.prompt.toLowerCase().includes(q) ||
        (c.tags||[]).some(t => t.toLowerCase().includes(q))
      );
      render(filtered);
    }

    // ── MODAL ──
    function openModal(id) {
      editId = id || null;
      currentTags = [];
      document.getElementById('f-title').value = '';
      document.getElementById('f-prompt').value = '';
      document.getElementById('f-cat').value = 'Pose';
      document.getElementById('f-img-url').value = '';
      document.getElementById('f-img-preview').style.display = 'none';
      document.getElementById('f-img-placeholder').style.display = 'block';
      document.getElementById('f-img-input').value = '';
      renderTagsInput();

      if (id) {
        const c = cards.find(x => x.id === id);
        document.getElementById('modal-title').textContent = 'Editar foto';
        document.getElementById('f-title').value = c.title;
        document.getElementById('f-prompt').value = c.prompt;
        document.getElementById('f-cat').value = c.cat || 'Pose';
        currentTags = [...(c.tags || [])];
        renderTagsInput();
        if (c.img) {
          document.getElementById('f-img-preview').src = c.img;
          document.getElementById('f-img-preview').style.display = 'block';
          document.getElementById('f-img-placeholder').style.display = 'none';
          if (c.img.startsWith('http')) document.getElementById('f-img-url').value = c.img;
        }
      } else {
        document.getElementById('modal-title').textContent = 'Nova foto de referência';
      }
      document.getElementById('modal').classList.remove('hidden');
    }

    function closeModal() { document.getElementById('modal').classList.add('hidden'); }
    function closeOnOverlay(e) { if (e.target.id === 'modal') closeModal(); }

    function previewImage(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = ev => {
        document.getElementById('f-img-preview').src = ev.target.result;
        document.getElementById('f-img-preview').style.display = 'block';
        document.getElementById('f-img-placeholder').style.display = 'none';
      };
      reader.readAsDataURL(file);
    }

    function previewUrl() {
      const url = document.getElementById('f-img-url').value.trim();
      if (url.startsWith('http')) {
        document.getElementById('f-img-preview').src = url;
        document.getElementById('f-img-preview').style.display = 'block';
        document.getElementById('f-img-placeholder').style.display = 'none';
      }
    }

    // ── TAGS ──
    function renderTagsInput() {
      const cont = document.getElementById('tags-container');
      cont.innerHTML = '';
      currentTags.forEach(t => {
        const span = document.createElement('span');
        span.className = 'tag-item';
        span.textContent = t + ' ×';
        span.onclick = () => { currentTags = currentTags.filter(x => x !== t); renderTagsInput(); };
        cont.appendChild(span);
      });
      const input = document.createElement('input');
      input.type = 'text'; input.id = 'tag-input';
      input.placeholder = currentTags.length ? '' : 'Ex: dourado, balões…';
      input.onkeydown = addTag;
      cont.appendChild(input);
    }

    function addTag(e) {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const val = e.target.value.replace(',','').trim();
        if (val && !currentTags.includes(val)) { currentTags.push(val); renderTagsInput(); }
        else if (e.target) e.target.value = '';
      }
    }

    // ── SALVAR ──
    function saveCard() {
      const title = document.getElementById('f-title').value.trim();
      const prompt = document.getElementById('f-prompt').value.trim();
      const cat = document.getElementById('f-cat').value;
      const urlInput = document.getElementById('f-img-url').value.trim();
      const previewSrc = document.getElementById('f-img-preview').src || '';
      let img = '';
      if (previewSrc.startsWith('data:')) img = previewSrc;
      else if (urlInput.startsWith('http')) img = urlInput;
      else if (previewSrc.startsWith('http')) img = previewSrc;

      if (!title) { showToast('⚠ Adicione um título!'); return; }
      if (!prompt) { showToast('⚠ Adicione o prompt!'); return; }

      if (editId) {
        const idx = cards.findIndex(x => x.id === editId);
        cards[idx] = { ...cards[idx], title, prompt, cat, tags: currentTags, img };
      } else {
        const maxId = cards.length ? Math.max(...cards.map(c => c.id)) : 0;
        cards.push({ id: maxId + 1, title, prompt, cat, tags: currentTags, img });
      }

      saveData(); filterCards(); closeModal();
      showToast(editId ? '✓ Foto atualizada!' : '✓ Foto adicionada!');
    }

    function editCard(id) { openModal(id); }

    function deleteCard(id) {
      if (!confirm('Excluir esta foto do catálogo?')) return;
      cards = cards.filter(c => c.id !== id);
      saveData(); filterCards();
      showToast('Foto removida.');
    }

    // ── COPIAR PROMPT ──
    function copyPrompt(id) {
      const c = cards.find(x => x.id === id);
      const text = c.prompt;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(() => showToast('✓ Prompt copiado!')).catch(() => fallbackCopy(text));
      } else { fallbackCopy(text); }
    }

    function fallbackCopy(text) {
      const ta = document.createElement('textarea');
      ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.select();
      document.execCommand('copy'); document.body.removeChild(ta);
      showToast('✓ Prompt copiado!');
    }

    // ── LIGHTBOX ──
    function openLightbox(src) {
      document.getElementById('lightbox-img').src = src;
      document.getElementById('lightbox').classList.remove('hidden');
    }
    function closeLightbox() { document.getElementById('lightbox').classList.add('hidden'); }

    // ── EXPORT ──
    function exportData() {
      const json = JSON.stringify(cards, null, 2);
      const blob = new Blob([json], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url;
      a.download = 'catalogo-ensaios.json'; a.click();
      URL.revokeObjectURL(url);
      showToast('✓ Backup exportado!');
    }

    // ── TOAST ──
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2400);
    }

    // ── TECLADO ──
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') { closeModal(); closeLightbox(); }
    });

    // ── INIT ──
    loadData();
    filterCards();
  </script>
</body>
</html>
